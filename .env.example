# Required: Slack credentials (secrets — never commit real values)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Optional: override any value from src/config/app.json via env var
# LOG_LEVEL=info                # debug | info | warn | error
# AWS_REGION=us-east-1
# CLOUDWATCH_LOG_GROUP=/chatops-ai-agent/app
# CLOUDWATCH_LOG_STREAM=slack-bot
# DYNAMODB_TABLE_NAME=slack-kiro-sessions
# ACP_COMMAND=kiro-cli acp
# ACP_DEFAULT_AGENT=senior      # omit to use kiro default agent
# CHANNEL_CONFIG_PATH=src/config/channels.json
# MAX_MESSAGE_LENGTH=10000
# PORT=3000
# REACTIONS_ENABLED=true
# REACTIONS_REMOVE_AFTER_REPLY=true
# REACTIONS_EMOJI_QUEUED=eyes
# REACTIONS_EMOJI_THINKING=brain
# REACTIONS_EMOJI_TOOL=wrench
# REACTIONS_EMOJI_CODING=technologist
# REACTIONS_EMOJI_WEB=globe_with_meridians
# REACTIONS_EMOJI_DONE=white_check_mark
# REACTIONS_EMOJI_ERROR=x
# REACTIONS_EMOJI_STALL_SOFT=hourglass_flowing_sand
# REACTIONS_EMOJI_STALL_HARD=turtle
# REACTIONS_TIMING_DEBOUNCE_MS=700
# REACTIONS_TIMING_STALL_SOFT_MS=10000
# REACTIONS_TIMING_STALL_HARD_MS=30000
# REACTIONS_TIMING_DONE_HOLD_MS=1500
# REACTIONS_TIMING_ERROR_HOLD_MS=2500
