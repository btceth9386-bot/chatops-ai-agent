SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret
CHANNEL_CONFIG_PATH=src/config/channels.json
MAX_MESSAGE_LENGTH=10000
PORT=3000
CLOUDWATCH_LOG_GROUP=/chatops-ai-agent
CLOUDWATCH_LOG_STREAM=slack-bot
# Optional: enable persistent session recovery in DynamoDB
DYNAMODB_TABLE_NAME=slack-kiro-sessions
# Optional: ACP command; must speak newline-delimited JSON over stdin/stdout
ACP_COMMAND=kiro-cli acp
